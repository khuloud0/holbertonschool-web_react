{
  "compilerOptions": {
    "target": "es5",
    "module": "es6",
    "strict": true,
    "esModuleInterop": true,
    "allowJs": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "lib": ["dom", "es2015"],
    "outDir": "dist"
  },
  "include": ["js/**/*.ts", "js/**/*.d.ts", "js/**/*.js"]
}
